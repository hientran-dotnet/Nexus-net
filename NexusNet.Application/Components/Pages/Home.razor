@page "/"

<title>Nexus Net - Home Page</title>

<!-- Navigation -->
<nav class="navbar">
    <div class="nav-container">
        <div class="nav-logo">
            <i class="fas fa-gamepad"></i>
            <span>Nexus Net</span>
        </div>
        <div class="nav-links">
            <a href="#features">Features</a>
            <a href="#testimonials">Reviews</a>
            <a href="#contact">Contact</a>
            <button class="nav-btn">Login</button>
        </div>
    </div>
</nav>

<!-- Hero Section -->
<section class="hero">
    <div class="hero-container">
        <div class="hero-content">
            <h1 class="hero-title">
                Connect, Play, and <span class="highlight">Build Communities</span>
            </h1>
            <p class="hero-description">
                Experience the next generation of gaming communication. Join millions of players
                worldwide in creating unforgettable gaming moments together.
            </p>
            <div class="hero-buttons">
                <button class="btn btn-primary">
                    Open Nexus Net in your browser
                </button>
            </div>
        </div>
        <div class="hero-image">
            <div class="hero-illustration">
                <div class="floating-card card-1">
                    <i class="fas fa-users"></i>
                    <span>Voice Chat</span>
                </div>
                <div class="floating-card card-2">
                    <i class="fas fa-exchange-alt"></i>
                    <span>Media Transfer</span>
                </div>
                <div class="floating-card card-3">
                    <i class="fas fa-comments"></i>
                    <span>Text Channels</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Features Section -->
<section class="features" id="features">
    <div class="container">
        <h2 class="section-title">Why Choose Nexus Net?</h2>
        <div class="features-grid">
            <div class="feature-card">
                <div class="feature-icon">
                    <i class="fas fa-microphone"></i>
                </div>
                <h3>Crystal Clear Voice</h3>
                <p>Experience lag-free, high-quality voice communication with noise suppression and echo cancellation.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">
                    <i class="fas fa-shield-alt"></i>
                </div>
                <h3>Secure & Private</h3>
                <p>Your conversations are protected with end-to-end encryption and advanced privacy controls.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">
                    <i class="fas fa-bolt"></i>
                </div>
                <h3>Lightning Fast</h3>
                <p>Built for performance with instant messaging, quick file sharing, and seamless screen sharing.</p>
            </div>
        </div>
    </div>
</section>

<!-- Testimonials Section -->
<section class="testimonials" id="testimonials">
    <div class="container">
        <h2 class="section-title">What Gamers Say</h2>
        <div class="testimonial-card">
            <div class="testimonial-content">
                <div class="quote-icon">
                    <i class="fas fa-quote-left"></i>
                </div>
                <blockquote>
                    "Nexus Net has completely transformed how our gaming community communicates.
                    The voice quality is exceptional, and the interface is so intuitive that
                    even new members can jump in instantly."
                </blockquote>
                <div class="testimonial-author">
                    <div class="author-avatar">
                        <i class="fas fa-user"></i>
                    </div>
                    <div class="author-info">
                        <h4>Alex Chen</h4>
                        <span>Guild Leader, Apex Legends</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Footer -->
<footer class="footer" id="contact">
    <div class="container">
        <div class="footer-content">
            <div class="footer-section">
                <div class="footer-logo">
                    <i class="fas fa-gamepad"></i>
                    <span>Nexus Net</span>
                </div>
                <p>Connecting gamers worldwide with seamless communication tools.</p>
                <div class="social-links">
                    <a href="#" class="social-link">
                        <i class="fab fa-twitter"></i>
                    </a>
                    <a href="#" class="social-link">
                        <i class="fab fa-discord"></i>
                    </a>
                    <a href="#" class="social-link">
                        <i class="fab fa-youtube"></i>
                    </a>
                    <a href="#" class="social-link">
                        <i class="fab fa-twitch"></i>
                    </a>
                </div>
            </div>
            <div class="footer-section">
                <h4>Product</h4>
                <ul>
                    <li><a href="#">Download</a></li>
                    <li><a href="#">Features</a></li>
                    <li><a href="#">Pricing</a></li>
                    <li><a href="#">Updates</a></li>
                </ul>
            </div>
            <div class="footer-section">
                <h4>Support</h4>
                <ul>
                    <li><a href="#">Help Center</a></li>
                    <li><a href="#">Contact Us</a></li>
                    <li><a href="#">Bug Reports</a></li>
                    <li><a href="#">Community</a></li>
                </ul>
            </div>
            <div class="footer-section">
                <h4>Company</h4>
                <ul>
                    <li><a href="#">About</a></li>
                    <li><a href="#">Careers</a></li>
                    <li><a href="#">Privacy</a></li>
                    <li><a href="#">Terms</a></li>
                </ul>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; 2025 Nexus Net. All rights reserved.</p>
        </div>
    </div>
</footer>